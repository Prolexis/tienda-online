NODE_ENV=development

# =============================================
# BASE DE DATOS - PostgreSQL
# =============================================
DATABASE_URL="postgresql://postgres:osafael456@localhost:5432/tienda_online?schema=public"
# =============================================
# AUTENTICACIÓN - JWT
